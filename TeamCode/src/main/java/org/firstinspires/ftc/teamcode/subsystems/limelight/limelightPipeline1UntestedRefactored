def runPipeline(image, llrobot):
    global draw_info
    global show_classifier_mask
    global classifier_contour_approx_mult
    global classifier_red_lb
    global classifier_red_ub
    global classifier_blue_lb
    global classifier_blue_ub
    global sample_x
    global sample_y
    global green_lb
    global green_ub
    global purple_lb1
    global purple_ub1
    global purple_lb2
    global purple_ub2

    # is_red = llrobot[0] > 0
    # camera_y = abs(llrobot[1])

    is_red = False
    camera_y = 49

    image = cv2.GaussianBlur(image, (3, 3), 0)
    img_hsv = cv2.cvtColor(image, cv2.COLOR_BGR2HSV)

    # mask image based on classifier========================
    classifier_lb = classifier_red_lb if is_red else classifier_blue_lb
    classifier_ub = classifier_red_ub if is_red else classifier_blue_ub
    valid_region_mask, classifier_col_mask, valid_region_y_bounds, successful = get_classifier_info(
        img_hsv,
        classifier_lb, classifier_ub,
        classifier_contour_approx_mult,
        show_debug=draw_info)
    if not successful:
        draw_left_text(image, "cannot find classifier", 3, 370)
        return contour_at_point(0, 0), classifier_col_mask if show_classifier_mask else image, [-1]

    image = cv2.bitwise_and(image, image, mask=valid_region_mask)

    # finding color contours=================================
    y1, y2 = valid_region_y_bounds
    cropped = img_hsv[y1:y2, :].copy()

    green_contours = get_contours(cropped, camera_y, green_lb, green_ub, None, None)
    purple_contours = get_contours(cropped, camera_y, purple_lb1, purple_ub1, purple_lb2, purple_ub2)
    num_contours = len(green_contours) + len(purple_contours)
    if num_contours == 0:
        draw_left_text(image, "no balls found", 3, 300)
        return contour_at_point(0, 0), classifier_col_mask if show_classifier_mask else image, [0]

    # combining, sorting, and segmenting color contours===========
    sorted_contours = []
    sorted_contours.extend(green_contours)
    sorted_contours.extend(purple_contours)
    sorted_contours.sort(key=centroid_x)
    if is_red:
        sorted_contours.reverse()
    rects = segment_contours(sorted_contours, camera_y, draw_info, image)

    # ignore result if balls are partially occluded
    r1 = rects[0]
    r2 = rects[len(rects)-1]
    if r1[0] <= 0 or r2[0] + r2[2] >= len(image[0]) - 1:
        draw_left_text(image, "occluded balls", 3, 300)
        return contour_at_point(sample_x, sample_y), classifier_col_mask if show_classifier_mask else image, [-1]

    num_balls = len(rects)
    if draw_info:
        dy = valid_region_y_bounds[1]
        for c in sorted_contours:
            c[:, 0, 1] += dy
        for i in range(len(rects)):
            x, y, w, h = rects[i]
            rects[i] = (x, y + dy, w, h)
        draw_combined_contours(image, sorted_contours)
        draw_rects(image, rects)

    draw_left_text(image, f"num contours: {num_contours}", 1, 300)
    draw_left_text(image, f"num balls: {num_balls}", 0, 250)

    show_sample_pixel(image, img_hsv, sample_x, sample_y, show_debug=False)
    return contour_at_point(sample_x, sample_y), classifier_col_mask if show_classifier_mask else image, [num_balls]


def get_classifier_info(img, lower_bounds, upper_bounds, contour_simplification_mult, show_debug):
    image = img.copy()
    width = len(image[0])
    height = len(image)

    # crop out edges of image when finding classifier mask
    global classifier_crop_left
    global classifier_crop_right
    global classifier_crop_tri_width
    global classifier_crop_tri_height
    crop_right = width - classifier_crop_right
    cv2.rectangle(image, (0, 0), (classifier_crop_left, height), 0, -1)
    cv2.rectangle(image, (crop_right, 0), (width, height), 0, -1)
    middle = width / 2
    pts = np.array(
        [[middle - classifier_crop_tri_width * 0.5, height],
         [middle, height - classifier_crop_tri_height],
         [middle + classifier_crop_tri_width * 0.5, height]],
        dtype=np.int32
    ).reshape((-1, 1, 2))
    cv2.fillPoly(image, [pts], color=0)

    classifier_mask = cv2.inRange(image, lower_bounds, upper_bounds)

    global classifier_erode_size
    global classifier_dilate_size
    if classifier_erode_size > 0:
        erode = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (classifier_erode_size, classifier_erode_size))
        classifier_mask = cv2.erode(classifier_mask, erode)
    if classifier_dilate_size > 0:
        dilate = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (classifier_dilate_size, classifier_dilate_size))
        classifier_mask = cv2.dilate(classifier_mask, dilate)

    contours, _ = cv2.findContours(classifier_mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

    if show_debug:
        classifier_mask = cv2.cvtColor(classifier_mask, cv2.COLOR_GRAY2BGR)

    mask = np.zeros((height, width), dtype=np.uint8)
    if len(contours) > 0:
        largest_contour = max(contours, key=cv2.contourArea)

        perimeter = cv2.arcLength(largest_contour, True)
        epsilon = contour_simplification_mult * perimeter
        approx = cv2.approxPolyDP(largest_contour, epsilon, closed=True)

        global classifier_max_edge_angle
        angle = classifier_max_edge_angle * math.pi / 180
        edge = longest_edge_from_approx(approx, angle)
        if edge is None:
            return mask, classifier_mask, [0, 0], False
        p1 = edge[0]
        p2 = edge[1]
        # generating rectangle above classifier
        if p1[0] > p2[0]:
            p1, p2 = p2, p1
        r1x = p1[0]
        r1y = p1[1]
        r2x = p2[0]
        r2y = p2[1]

        global min_valid_classifier_width
        if abs(r2x - r1x) < min_valid_classifier_width:
            return mask, classifier_mask, [0, 0], False

        global classifier_window_width_mult
        global classifier_window_extra_space_down
        global classifier_window_height
        dx = r2x - r1x
        dy = r2y - r1y
        r1x -= dx * classifier_window_width_mult
        r1y -= dy * classifier_window_width_mult
        r2x += dx * classifier_window_width_mult
        r2y += dy * classifier_window_width_mult

        r1y += classifier_window_extra_space_down
        r2y += classifier_window_extra_space_down

        height_window = classifier_window_height
        height_window += classifier_window_extra_space_down

        r3x = r2x
        r3y = r2y - height_window
        r4x = r1x
        r4y = r1y - height_window

        if show_debug:
            cv2.polylines(
                classifier_mask,
                [approx],
                isClosed=True,
                color=(0, 255, 0),
                thickness=2
            )
            cv2.circle(classifier_mask, (int(p1[0]), int(p1[1])), 20, (255, 0, 255), -1)
            cv2.circle(classifier_mask, (int(p2[0]), int(p2[1])), 20, (255, 0, 255), -1)
            cv2.circle(classifier_mask, (int(r1x), int(r1y)), 20, (0, 0, 255), -1)
            cv2.circle(classifier_mask, (int(r2x), int(r2y)), 20, (0, 0, 255), -1)
            cv2.circle(classifier_mask, (int(r3x), int(r3y)), 20, (0, 0, 255), -1)
            cv2.circle(classifier_mask, (int(r4x), int(r4y)), 20, (0, 0, 255), -1)

        pts = np.array(
            [[r1x, r1y],
             [r2x, r2y],
             [r3x, r3y],
             [r4x, r4y]],
            dtype=np.int32
        ).reshape((-1, 1, 2))

        cv2.fillPoly(mask, [pts], color=255)

        y_bounds = [
            max(0, int(min(r3y, r4y))),
            min(height, math.ceil(max(r1y, r2y)))
        ]
        return mask, classifier_mask, y_bounds, True
    return mask, classifier_mask, [0, 0], False


def get_contours(hsv, camera_y, lower_bounds, upper_bounds, lower_bounds2, upper_bounds2):
    img_threshold = cv2.inRange(hsv, lower_bounds, upper_bounds)
    if lower_bounds2 is not None and upper_bounds2 is not None:
        mask2 = cv2.inRange(hsv, lower_bounds2, upper_bounds2)
        img_threshold = cv2.bitwise_or(img_threshold, mask2)

    global ball_mask_erode_size
    global ball_mask_dilate_size
    if ball_mask_dilate_size > 0:
        dilate = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (ball_mask_dilate_size, ball_mask_dilate_size))
        img_threshold = cv2.dilate(img_threshold, dilate)
    if ball_mask_erode_size > 0:
        erode = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (ball_mask_erode_size, ball_mask_erode_size))
        img_threshold = cv2.erode(img_threshold, erode)

    # find contours in the new binary image
    contours, _ = cv2.findContours(img_threshold, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

    # filter out specks
    # y=29.62963x+488.88889
    min_area = 29.62963 * camera_y + 488.88889

    min_accepted_area = -1
    filtered_contours = []
    for c in contours:
        area = cv2.contourArea(c)
        if area >= min_area:
            filtered_contours.append(c)
            if min_accepted_area < 0 or area < min_accepted_area:
                min_accepted_area = area
    contours = filtered_contours
    # print(f"min area: {int(min_area)} | min accepted: {min_accepted_area}")

    # filter out outliers by y value
    if len(contours) > 0:
        total_y = 0
        centroid_ys = []
        for c in contours:
            cy = centroid_y(c)
            centroid_ys.append(cy)
            total_y += cy
        mean_y = total_y / len(contours)

        max_dist_from_mean = 230
        filtered_contours = []
        for i in range(len(contours)):
            cy = centroid_ys[i]
            diff = abs(cy - mean_y)
            if diff <= max_dist_from_mean:
                filtered_contours.append(contours[i])
        contours = filtered_contours

    return contours


def segment_contours(contours, camera_y, show_debug, image):
    single_ball_size = camera_y * 2.53333 + 55.88333
    another_ball_threshold = 0.8
    first_ball_size_mult = 1.1

    segmented_rects = []
    first_w = 0
    other_w = 0
    avg_w = 0
    for i in range(len(contours)):
        contour = contours[i]
        x, y, w, h = cv2.boundingRect(contour)
        if i > 0:
            other_w += w
        else:
            first_w = w

        ball_size = single_ball_size
        if i == 0:
            ball_size *= first_ball_size_mult
        ratio = w / ball_size

        if ratio > 1 + another_ball_threshold:
            split_amount = int(ratio)
            if ratio % 1 > another_ball_threshold:
                split_amount += 1
            split_width = w / split_amount
            for i in range(split_amount):
                split_rect = x + i * split_width, y, split_width, h
                segmented_rects.append(split_rect)
        else:
            rect = x, y, w, h
            segmented_rects.append(rect)

    if len(contours) > 1:
        avg_w = (first_w + other_w) / len(contours)
        other_w /= len(contours) - 1
    elif len(contours) == 1:
        avg_w = first_w

    if show_debug:
        draw_right_text(image, f"avg w: {avg_w}", 1, 300)
        draw_right_text(image, f"avg w: {avg_w}", 1, 300)

    return segmented_rects

# drawing functions========================
def show_sample_pixel(image, img_hsv, samplex, sampley, show_debug):
    h, s, b = img_hsv[sampley, samplex]

    global min_hue
    global max_hue
    global min_sat
    global max_sat
    global min_bright
    global max_bright
    min_hue = min(h, min_hue)
    max_hue = max(h, max_hue)
    min_sat = min(s, min_sat)
    max_sat = max(s, max_sat)
    min_bright = min(b, min_bright)
    max_bright = max(b, max_bright)

    if show_debug:
        draw_right_text(image, f"color: {h:3d} {s:3d} {b:3d}", 2, 400)
        draw_right_text(image, f"min col: {min_hue:3d} {min_sat:3d} {min_bright:3d}", 1, 400)
        draw_right_text(image, f"max col: {max_hue:3d} {max_sat:3d} {max_bright:3d}", 0, 400)


def draw_left_text(image, text, row, width):
    h = len(image)
    y = h - 70 * (row + 1)
    cv2.rectangle(image, (0, y), (width, y + 60), (0, 0, 0), -1)
    cv2.putText(
        image, text, (20, y + 40),
        cv2.FONT_HERSHEY_SIMPLEX,
        1.0, (0, 255, 0), 2,
        cv2.LINE_AA
    )
def draw_right_text(image, text, row, width):
    x = len(image[0]) - width
    y = len(image) - 70 * (row + 1)
    cv2.rectangle(image, (x, y), (width, y + 60), (0, 0, 0), -1)
    cv2.putText(
        image, text, (x + 20, y + 40),
        cv2.FONT_HERSHEY_SIMPLEX,
        1.0, (0, 255, 0), 2,
        cv2.LINE_AA
    )


def draw_combined_contours(image, contours):
    contours = [c for c in contours if c is not None and len(c) > 0 and c.shape[0] > 0]
    if len(contours) <= 0:
        return
    cv2.drawContours(image, contours, -1, (255, 255, 255), 2)


def draw_rects(image, rects):
    for i in range(len(rects)):
        x, y, w, h = rects[i]
        x = int(x)
        y = int(y)
        w = int(w)
        h = int(h)
        cv2.rectangle(image, (x, y), (x + w, y + h), (0, 0, 0), 3)
        cv2.rectangle(image, (x - 5, y - 50), (x + 20, y), (0, 0, 0), -1)
        cv2.putText(image, f"{i}", (x, y - 20),
                    cv2.FONT_HERSHEY_SIMPLEX,
                    1.0, (255, 255, 255), 2, cv2.LINE_AA)


# utility functions=========================
def centroid_x(contour):
    M = cv2.moments(contour)
    if M["m00"] == 0:
        return 0.0
    return M["m10"] / M["m00"]


def centroid_y(contour):
    M = cv2.moments(contour)
    if M["m00"] == 0:
        return 0.0
    return M["m01"] / M["m00"]


def centroid_xy(contour):
    M = cv2.moments(contour)
    if M["m00"] == 0:
        return 0.0, 0.0
    cx = M["m10"] / M["m00"]
    cy = M["m01"] / M["m00"]
    return cx, cy


def contour_at_point(x, y, size=6):
    # contour shape: (N, 1, 2) int32
    s = size
    pts = np.array([
        [x - s, y - s],
        [x + s, y - s],
        [x + s, y + s],
        [x - s, y + s],
    ], dtype=np.int32).reshape((-1, 1, 2))
    return pts


# finds the longest edge from a polygon that does not exceed the max angle taken from the horizontal
def longest_edge_from_approx(approx, max_angle_rad_from_horizontal):
    pts = approx.reshape(-1, 2)  # (N, 2)
    n = len(pts)
    max_len = 0.0
    best_edge = None

    for i in range(n):
        p1 = pts[i]
        p2 = pts[(i + 1) % n]  # wrap around

        length = np.linalg.norm(p2 - p1)
        dy = p2[1] - p1[1]
        dx = p2[0] - p1[0]
        angle = abs(math.atan2(dy, dx))

        if length > max_len and angle < max_angle_rad_from_horizontal:
            max_len = length
            best_edge = (tuple(p1), tuple(p2))
    return best_edge

# returns length, (point1, point2)
def longest_2edges_from_approx(approx):
    pts = approx.reshape(-1, 2)  # (N, 2)
    n = len(pts)

    max_len = 0.0
    best_edge = None
    max_len2 = 0
    best_edge2 = None

    for i in range(n):
        p1 = pts[i]
        p2 = pts[(i + 1) % n]  # wrap around

        length = np.linalg.norm(p2 - p1)

        if length > max_len:
            max_len2 = length
            best_edge2 = best_edge
            max_len = length
            best_edge = (tuple(p1), tuple(p2))
        elif length > max_len2:
            max_len2 = length
            best_edge = (tuple(p1), tuple(p2))

    return max_len, best_edge, max_len2, best_edge2

