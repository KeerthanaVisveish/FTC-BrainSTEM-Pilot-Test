classifier_max_edge_angle = 45

# specifying properties of classifier window mask
classifier_window_width_mult = 0.25
classifier_window_extra_space_down = 15
classifier_window_height = 90

# ball color mask bounds
green_lb = (50, 35, 125)
green_ub = (70, 255, 230)
purple_lb1 = (150, 70, 60)
purple_ub1 = (180, 150, 230)
purple_lb2 = (0, 70, 60)
purple_ub2 = (10, 150, 230)

# ball color mask processing
ball_mask_erode_size = 10
ball_mask_dilate_size = 10

# debugging
sample_x = 1000
sample_y = 350
