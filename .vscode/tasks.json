{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FTC: Build TeamCode",
      "type": "shell",
      "command": "./gradlew",
      "args": [
        ":TeamCode:assembleDebug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "/Library/Java/JavaVirtualMachines/jdk-17.jdk/Contents/Home",
          "ANDROID_HOME": "${env:HOME}/Library/Android/sdk"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "FTC: Deploy TeamCode",
      "type": "shell",
      "command": "./gradlew",
      "args": [
        ":TeamCode:installDebug"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "/Library/Java/JavaVirtualMachines/jdk-17.jdk/Contents/Home",
          "ANDROID_HOME": "${env:HOME}/Library/Android/sdk"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
